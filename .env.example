# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GA_ID=

# --- Sepay (Vietnamese bank-transfer reconciliation) ---
# Get from https://my.sepay.vn — API key authorizes incoming webhooks.
SEPAY_API_KEY=
SEPAY_BANK_ACCOUNT=
SEPAY_BANK_BRAND=MBBank
SEPAY_ACCOUNT_NAME=

# --- Stripe (optional, set STRIPE_ENABLED=true to enable) ---
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=CareerFlow <no-reply@yourcv.net>

# --- AI provider ---
# Set AI_PROVIDER=deepseek to use DeepSeek V4 Flash (cheaper, OpenAI-compatible).
# Set AI_PROVIDER=openai (default) to use OpenAI.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Get from https://platform.deepseek.com — used when AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# --- Cron (must be set in production) ---
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Rate limiting (Upstash Redis, optional) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (optional) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
